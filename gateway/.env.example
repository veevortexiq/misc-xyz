# vArena gateway config — copy to .env and fill in.

# Public port the gateway listens on (behind Caddy/nginx TLS in production).
PORT=8080

# The shared vArena (t3) instance — loopback only, never public.
T3_TARGET=http://127.0.0.1:3773

# Bearer token for vArena. Mint once against the instance's base-dir:
#   t3 auth session issue --token-only --ttl 365d --label varena-gateway
T3_BEARER=

# Firebase (project saasvortex-dryrunproai). API key is the auto-created Firebase browser key.
FIREBASE_PROJECT_ID=saasvortex-dryrunproai
FIREBASE_API_KEY=AIzaSyD6lw5DXGizWskm8e9ImBKmUhEF8ZLA4FQ
FIREBASE_AUTH_DOMAIN=saasvortex-dryrunproai.firebaseapp.com

# Path to the Admin SDK service-account JSON (used to verify Firebase ID tokens).
GOOGLE_APPLICATION_CREDENTIALS=../secrets/vortexspace-sa.json

# Long random string used to sign the gateway session cookie. Generate, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
GATEWAY_SECRET=

# Comma-separated team emails allowed in, or "*" for any verified Google account.
# Empty = gateway refuses to start (fail closed).
ALLOWLIST=

# Gateway session lifetime and cookie security.
SESSION_TTL=12h
COOKIE_SECURE=true

# --- In-app preview (optional) ---
# If set, the gateway starts a 2nd listener on PREVIEW_PORT that proxies ALL paths + WS
# to PREVIEW_TARGET behind the same login cookie, giving the app its own origin so its
# relative /api calls resolve to the app (not vArena). Leave PREVIEW_PORT unset to disable.
PREVIEW_PORT=8090
PREVIEW_TARGET=http://127.0.0.1:3000
# The URL the vArena /preview iframe loads by default. Baked into the web build (VITE_*).
# Set to the public preview origin, e.g. https://172.190.70.72:8443
# VITE_PREVIEW_URL must be set at BUILD time (vp build), not here — see deploy notes.
